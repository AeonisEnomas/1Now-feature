# ─────────────────────────────────────────────────────────────
# 1Now Social Studio — Frontend env
# Copy to "frontend/.env" (local) or set in Vercel (production).
# Leave VITE_API_URL blank to run in DEMO MODE (localStorage + templates).
# ─────────────────────────────────────────────────────────────

# Supabase — used for AUTH only (signup / login / session)
#   Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend REST API base URL (profile data + AI go through here)
#   Local:      http://localhost:4000
#   Production: https://<your-backend>.onrender.com
VITE_API_URL=http://localhost:4000
