# ─────────────────────────────────────────────────────────────
# 1Now Social Studio — Backend env (Express + PostgreSQL)
# Copy to "backend/.env" (local) or set in Render (production).
# ─────────────────────────────────────────────────────────────

# Local port. On Render this is provided automatically — leave it.
PORT=4000

# Allowed browser origin(s) for CORS — comma-separated.
#   Local:      http://localhost:5173
#   Production: your Vercel URL, e.g. https://1now-feature.vercel.app
# (localhost and any *.vercel.app origin are always allowed automatically.)
CORS_ORIGIN=http://localhost:5173

# Supabase Postgres connection string.
#   Dashboard → Settings → Database → Connection string.
#   IMPORTANT: use the "Session pooler" URI (IPv4) — the direct db.<ref>.supabase.co
#   host is IPv6-only and fails on many hosts (Render included).
#   Looks like: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase project — used to validate the user's auth token
#   Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Ollama Cloud — the AI key lives ONLY here (never in the frontend)
#   https://ollama.com → Settings → API keys
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_BASE_URL=https://ollama.com
